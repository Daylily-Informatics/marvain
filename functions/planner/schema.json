{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PlannerOutput",
  "description": "Schema for validating planner LLM output",
  "type": "object",
  "definitions": {
    "memoryItem": {
      "type": "object",
      "properties": {
        "content": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "description": "The memory content"
        },
        "participants": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Person IDs or names involved"
        }
      },
      "required": ["content"],
      "additionalProperties": false
    }
  },
  "properties": {
    "episodic": {
      "type": "array",
      "description": "Time-bound events, observations, transcripts, and lived session facts",
      "items": {"$ref": "#/definitions/memoryItem"},
      "default": []
    },
    "semantic": {
      "type": "array",
      "description": "Stable facts and learned knowledge",
      "items": {"$ref": "#/definitions/memoryItem"},
      "default": []
    },
    "procedural": {
      "type": "array",
      "description": "How-to instructions, routines, and action recipes",
      "items": {"$ref": "#/definitions/memoryItem"},
      "default": []
    },
    "preference": {
      "type": "array",
      "description": "User likes, dislikes, defaults, and choices",
      "items": {"$ref": "#/definitions/memoryItem"},
      "default": []
    },
    "relationship": {
      "type": "array",
      "description": "Connections among people, agents, devices, and roles",
      "items": {"$ref": "#/definitions/memoryItem"},
      "default": []
    },
    "location": {
      "type": "array",
      "description": "Location and space-specific facts or observations",
      "items": {"$ref": "#/definitions/memoryItem"},
      "default": []
    },
    "device": {
      "type": "array",
      "description": "Device capabilities, state, routing, and behavior",
      "items": {"$ref": "#/definitions/memoryItem"},
      "default": []
    },
    "policy": {
      "type": "array",
      "description": "Consent, privacy, governance, and audit-supporting notes",
      "items": {"$ref": "#/definitions/memoryItem"},
      "default": []
    },
    "actions": {
      "type": "array",
      "description": "Proposed actions for the agent to execute",
      "items": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "description": "Action type identifier (for example send_message or create_memory)"
          },
          "payload": {
            "type": "object",
            "description": "Action-specific parameters"
          },
          "required_scopes": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Scopes required to execute this action"
          },
          "auto_approve": {
            "type": "boolean",
            "description": "If true, action is auto-approved for execution",
            "default": false
          }
        },
        "required": ["kind"],
        "additionalProperties": false
      },
      "default": []
    }
  },
  "additionalProperties": false
}
